# PostgreSQL Zugangsdaten (für lokale Entwicklung; in Produktion ändern!)
POSTGRES_USER=rechnung
POSTGRES_PASSWORD=rechnung_pw
POSTGRES_DB=rechnung

# Port, auf dem die Web-App erreichbar ist
WEB_PORT=8000

# Login: 3 Benutzer (Format user:passwort,...) – nur beim ERSTEN Start in die DB übernommen
APP_USERS=anna:passwort,bernd:passwort,clara:passwort
# Admin-Account (kann Benutzer verwalten) – nur beim ersten Start angelegt
ADMIN_USER=admin
ADMIN_PASSWORD=admin
# Geheimnis zum Signieren der Login-Sitzung (in Produktion unbedingt ändern!)
SESSION_SECRET=bitte-in-produktion-aendern-1234567890

# E-Mail-Versand über MailHog (Testserver, kein echter Versand)
SMTP_HOST=mailhog
SMTP_PORT=1025
MAIL_FROM=rechnung@example.com
MAILHOG_UI_PORT=8025

# Reverse-Proxy (rechnungen.localhost / mail.localhost)
PROXY_PORT=80
